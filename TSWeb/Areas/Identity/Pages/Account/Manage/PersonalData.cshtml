@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3>@ViewData["Title"]</h3>

<div class="row">
    <div class="col-md-6">
        <p class="text-dark">Your account contains personal data that you have given us. This page allows you to download or delete that data.</p>
        <p>
            <strong class="text-dark">Deleting this data will permanently remove your account, and this cannot be recovered.</strong>
        </p>
        <div class="d-flex align-items-center">
            <form id="download-data" asp-page="DownloadPersonalData" method="post" class="me-2">
                <button class="btn bg-dark text-yellow" type="submit">Download</button>
            </form>
            <p class="mb-0">
                <a id="delete" class="btn bg-dark text-yellow" asp-page="DeletePersonalData">Delete</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
