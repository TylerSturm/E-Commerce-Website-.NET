@using TS.Models.ViewModels
@using TS.Utility
@using Microsoft.AspNetCore.Identity

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] COLAS</title>
    <!-- Toastr CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    <!-- jQuery (required for Toastr) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

    <!-- Toastr JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TSWeb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~//cdn.datatables.net/2.3.2/css/dataTables.dataTables.min.css" />
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
</head>
<body>
    <header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-primary bg-dark border-bottom box-shadow mb-0" style="padding: 0.5rem 1rem;">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="~/Pictures/Logo.png" alt="COLAS" style="height:40px;" /> 
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link text-yellow" asp-area="" asp-controller="Home" asp-action="Index" style="font-size: 0.875rem;">Home</a>
                    </li>
                        <li class="nav-item">
                            <a class="nav-link text-yellow" asp-area="" asp-controller="Home" asp-action="Privacy" style="font-size: 0.875rem;">Privacy</a>
                        </li>
                        @if (User.IsInRole(SD.Role_Admin))
                        { 
                            <li class="nav-item dropdown">
                                <a class="text-yellow nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Content Management
                                </a>
                                <ul class="dropdown-menu">
                                    <li class="nav-item">
                                        <a class="dropdown-item text-dark" asp-area="Admin" asp-controller="Category" asp-action="Index">Category</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="dropdown-item text-dark" asp-area="Admin" asp-controller="Product" asp-action="Index">Product</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="dropdown-item text-dark" asp-area="Admin" asp-controller="Company" asp-action="Index">Company</a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Customer) || User.IsInRole(SD.Role_Employee) || User.IsInRole(SD.Role_Company))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-yellow" asp-area="Customer" asp-controller="History" asp-action="Index">
                                    History
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link text-yellow" asp-area="Customer" asp-controller="Cart" asp-action="Index">
                                Cart (@(ViewBag.ItemCount ?? 0)) 
                            </a>
                        </li>
                    </ul>
                    <partial name="_loginPartial"/>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-2">
            <partial name="_Notification" />
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-dark text-yellow">
        <div class="container-fluid text-yellow text-center p-0" style="padding: 0.5rem 0;">
            &copy; 2025 - Colas - <a class="text-yellow" asp-area="" asp-controller="Home" asp-action="Privacy" style="font-size: 0.875rem;">Privacy</a> <!-- Adjust font size -->
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~//cdn.datatables.net/2.3.2/js/dataTables.min.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.tiny.cloud/1/vxlj7cnv11sr7slfmeirotfpxz7p21lffbu2wrtws0chvn7q/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
